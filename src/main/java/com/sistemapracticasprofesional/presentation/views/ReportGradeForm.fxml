<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistemapracticasprofesional.presentation.controllers.ReportGradeFormController">

    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" prefHeight="80.0">
                <padding>
                    <Insets bottom="18" left="20" right="24" top="18" />
                </padding>

                <Label style="-fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #222222;" text="Evaluar reportes">
                    <font><Font size="28" /></font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <ImageView fx:id="logoImageView" fitHeight="70.0" fitWidth="80.0" preserveRatio="true">
                    <image>
                        <Image url="@/C:/Users/dario/OneDrive/Documents/Universidad%20Veracruzana/Logo_de_la_Universidad_Veracruzana.png" />
                    </image>
                </ImageView>
            </HBox>
        </VBox>
    </top>


    <center>
        <HBox alignment="TOP_CENTER">
            <padding>
                <Insets bottom="40" left="40" right="40" top="40" />
            </padding>


            <VBox prefHeight="580.0" prefWidth="560.0" spacing="0.0" style="-fx-background-color: white;                          -fx-border-color: #1e90ff;                          -fx-border-width: 2;                          -fx-border-radius: 4;                          -fx-background-radius: 4;">

                <padding>
                    <Insets bottom="28" left="28" right="28" top="24" />
                </padding>


                <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1a1a1a;" text="Evaluacion">
                    <font><Font size="18" /></font>
                    <VBox.margin><Insets bottom="20" /></VBox.margin>
                </Label>


                <Label style="-fx-font-size: 13px; -fx-text-fill: #333333;" text="Observaciones">
                    <VBox.margin><Insets bottom="6" /></VBox.margin>
                </Label>

                <TextArea fx:id="txtObservationBox" prefHeight="200.0" promptText="Escriba sus observaciones aquí..." style="-fx-border-color: #aaaaaa;                                  -fx-border-radius: 4;                                  -fx-background-radius: 4;                                  -fx-font-size: 13px;" wrapText="true">
                    <VBox.margin><Insets bottom="24" /></VBox.margin>
                </TextArea>


                <Label style="-fx-font-size: 13px; -fx-text-fill: #333333;" text="Calificacion">
                    <VBox.margin><Insets bottom="6" /></VBox.margin>
                </Label>

                <TextField fx:id="txtGradeField" maxWidth="200.0" prefWidth="200.0" promptText="0 – 100" style="-fx-border-color: #aaaaaa;                                   -fx-border-radius: 4;                                   -fx-background-radius: 4;                                   -fx-font-size: 13px;">
                    <VBox.margin><Insets bottom="32" /></VBox.margin>
                </TextField>


                <HBox alignment="CENTER" spacing="16.0">
                    <Button fx:id="btnCancel" onAction="#onClickCancel" prefWidth="200.0" style="-fx-background-color: #333333;                                    -fx-text-fill: white;                                    -fx-background-radius: 6;                                    -fx-font-size: 13px;                                    -fx-cursor: hand;                                    -fx-padding: 10 20 10 20;" text="Cancelar Evaluacion" />

                    <Button fx:id="btnFinish" onAction="#onClickFinish" prefWidth="200.0" style="-fx-background-color: #222222;                                    -fx-text-fill: white;                                    -fx-background-radius: 6;                                    -fx-font-size: 13px;                                    -fx-cursor: hand;                                    -fx-padding: 10 20 10 20;" text="Terminar Evaluacion" />
                </HBox>

            </VBox>
        </HBox>
    </center>

</BorderPane>
