<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistemapracticasprofesional.presentation.controllers.GradeReportController">

    <!-- ══════════════════════════════════════════
         HEADER
    ══════════════════════════════════════════ -->
    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-width: 0 0 1 0;">
            <HBox alignment="CENTER_LEFT" prefHeight="80.0">
                <padding>
                    <Insets bottom="0" left="24" right="24" top="0" />
                </padding>

                <Label style="-fx-font-weight: bold; -fx-font-size: 28px; -fx-text-fill: #222222;" text="Evaluar reportes">
                    <font><Font size="28" /></font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <!-- UV Logo placeholder — replace src with actual asset path -->
                <ImageView fx:id="logoImageView" fitHeight="70.0" fitWidth="80.0" preserveRatio="true">
                    <image>
                        <Image url="@/C:/Users/dario/OneDrive/Documents/Universidad%20Veracruzana/Logo_de_la_Universidad_Veracruzana.png" />
                    </image>
                </ImageView>
            </HBox>
        </VBox>
    </top>

    <!-- ══════════════════════════════════════════
         CENTER — TabPane with report lists
    ══════════════════════════════════════════ -->
    <center>
        <VBox alignment="TOP_CENTER" spacing="0">
            <padding>
                <Insets bottom="24" left="40" right="40" top="24" />
            </padding>

            <TabPane fx:id="tabPane" prefHeight="82.0" prefWidth="431.0" style="-fx-background-color: transparent;" tabClosingPolicy="UNAVAILABLE">

                <!-- ─── Tab 1: Reportes Mensuales ─── -->
                <Tab fx:id="tabMonthlies" text="Reportes mensuales">
               <content>
                  <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                     <content>
                        <VBox fx:id="vBoxMonthlies" alignment="TOP_CENTER" spacing="16.0">
                           <padding>
                              <Insets bottom="20" left="0" right="0" top="20" />
                           </padding>
                        </VBox>
                     </content>
                  </ScrollPane>
               </content></Tab>

                <!-- ─── Tab 2: Reportes Parciales ─── -->
                <Tab fx:id="tabPartials" text="Reportes parciales">
                    <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
                     <content>
                                <VBox fx:id="vBoxPartials" alignment="TOP_CENTER" spacing="16.0">
                                    <padding>
                                        <Insets bottom="20" left="0" right="0" top="20" />
                                    </padding>
                                    <!-- Cards loaded dynamically by controller -->
                                </VBox>
                     </content>
                        </ScrollPane>
                    </content>
                </Tab>

            </TabPane>
        </VBox>
    </center>

</BorderPane>
