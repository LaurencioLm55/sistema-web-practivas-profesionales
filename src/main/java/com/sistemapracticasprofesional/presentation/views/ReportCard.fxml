<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox alignment="CENTER_LEFT" prefWidth="820.0" spacing="16.0" style="-fx-background-color: white;              -fx-border-color: #dddddd;              -fx-border-radius: 8;              -fx-background-radius: 8;              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 2);" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sistemapracticasprofesional.presentation.controllers.ReportCardController">
    <padding>
        <Insets bottom="18" left="20" right="24" top="18" />
    </padding>


    <Label alignment="CENTER" style="-fx-font-size: 22px; -fx-text-fill: #555555;" text="ⓘ" />


    <VBox spacing="3.0" HBox.hgrow="ALWAYS">

        <Label fx:id="lblTitle" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #1a1a1a;" text="Reporte">
            <font><Font size="16" /></font>
        </Label>

        <Label fx:id="labelNombreAlumno" style="-fx-font-size: 13px; -fx-text-fill: #777777;" text="Nombre del alumno" />

        <Label fx:id="labelMatricula" style="-fx-font-size: 13px; -fx-text-fill: #777777;" text="Matrícula" />

        <Label fx:id="labelSeccion" style="-fx-font-size: 13px; -fx-text-fill: #777777;" text="Sección" />

    </VBox>

    <Button fx:id="btnGrade" onAction="#onClickGrade" style="-fx-background-color: white;                    -fx-border-color: #aaaaaa;                    -fx-border-radius: 6;                    -fx-background-radius: 6;                    -fx-font-size: 13px;                    -fx-cursor: hand;                    -fx-padding: 6 18 6 18;" text="Evaluar">
    </Button>

</HBox>
